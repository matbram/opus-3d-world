{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "post-compact"
            ],
            "command": "bash",
            "timeout": 8,
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "pre-compact"
            ],
            "command": "bash",
            "timeout": 8,
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "session-end"
            ],
            "command": "bash",
            "timeout": 8,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "session-start"
            ],
            "command": "bash",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": "startup|clear|compact"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "stop"
            ],
            "command": "bash",
            "timeout": 8,
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "stop-failure"
            ],
            "command": "bash",
            "timeout": 8,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "subagent-stop"
            ],
            "command": "bash",
            "timeout": 8,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "args": [
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/adh.sh",
              "user-prompt-submit"
            ],
            "command": "bash",
            "timeout": 8,
            "type": "command"
          }
        ]
      }
    ]
  }
}